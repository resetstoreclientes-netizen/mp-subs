{% comment %}
  MP Subscription Block - Premium design with configurable shipping modal
{% endcomment %}

<div id="mp-subscription-block"
  data-shop="{{ shop.permanent_domain }}"
  data-app-url="{{ block.settings.app_url }}"
  data-product-title="{{ product.title | escape }}"
  data-product-id="{{ product.id }}"
  data-product-price="{{ product.price | money_without_currency }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-show-address="{{ block.settings.show_address }}"
  data-show-city="{{ block.settings.show_city }}"
  data-show-phone="{{ block.settings.show_phone }}"
  data-show-province="{{ block.settings.show_province }}"
  data-show-postal="{{ block.settings.show_postal }}"
  data-modal-bg="{{ block.settings.modal_bg_color }}"
  data-modal-overlay="{{ block.settings.modal_overlay_color }}"
  data-modal-title="{{ block.settings.modal_title }}"
  data-modal-subtitle="{{ block.settings.modal_subtitle }}"
  data-modal-radius="{{ block.settings.modal_border_radius }}"
  data-input-radius="{{ block.settings.input_border_radius }}">
  <div class="mps-loading">Cargando opciones...</div>
</div>

<style>
  #mp-subscription-block {
    margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
    font-family: inherit;
    max-width: 500px;
  }
  .mps-loading { color: #555; font-size: 14px; padding: 16px 0; }
  .mps-load-error { color: #d72c0d; font-size: 14px; padding: 16px 0; }

  /* Section title */
  .mps-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: {{ block.settings.text_color }};
  }

  /* Plan cards */
  .mps-plan {
    border: 2px solid #e1e1e1;
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 10px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    background: #fff;
  }
  .mps-plan:hover { border-color: {{ block.settings.accent_color }}; }
  .mps-plan.selected {
    border-color: {{ block.settings.accent_color }};
    background: {{ block.settings.accent_color }}10;
  }
  .mps-plan-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .mps-plan-left { display: flex; align-items: flex-start; gap: 10px; flex: 1; }
  .mps-radio {
    width: 20px; height: 20px; border-radius: 50%;
    border: 2px solid #ccc; margin-top: 2px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .mps-plan.selected .mps-radio {
    border-color: {{ block.settings.accent_color }};
  }
  .mps-radio-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: {{ block.settings.accent_color }};
    display: none;
  }
  .mps-plan.selected .mps-radio-dot { display: block; }
  .mps-plan-name { font-weight: 700; font-size: 16px; color: #111; }
  .mps-plan-desc { font-size: 13px; color: #555; margin-top: 2px; }
  .mps-plan-right { text-align: right; flex-shrink: 0; }
  .mps-plan-price { font-weight: 800; font-size: 20px; color: #111; }
  .mps-plan-original {
    font-size: 13px; color: #999;
    text-decoration: line-through; margin-left: 4px;
  }
  .mps-plan-daily { font-size: 12px; color: #555; }

  /* Discount badge */
  .mps-badge {
    position: absolute; top: -10px; right: 12px;
    background: {{ block.settings.accent_color }};
    color: #fff; font-size: 12px; font-weight: 700;
    padding: 3px 10px; border-radius: 4px;
  }

  /* One-time purchase card */
  .mps-onetime {
    border: 2px solid #e1e1e1;
    border-radius: 10px;
    padding: 16px 18px;
    margin-top: 16px;
    cursor: pointer;
    background: #f8f8f8;
    transition: all 0.2s;
  }
  .mps-onetime:hover { border-color: #999; }
  .mps-onetime.selected {
    border-color: {{ block.settings.accent_color }};
    background: {{ block.settings.accent_color }}08;
  }
  .mps-onetime-cons {
    display: flex; gap: 16px; margin-top: 8px; font-size: 12px; color: #c00;
  }

  /* CTA Button */
  .mps-cta {
    width: 100%; padding: 16px; margin-top: 16px;
    background: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none; border-radius: 10px;
    font-size: 17px; font-weight: 700;
    cursor: pointer; transition: opacity 0.2s;
  }
  .mps-cta:hover { opacity: 0.9; }
  .mps-cta:disabled { opacity: 0.5; cursor: not-allowed; }

  .mps-trust {
    text-align: center; margin-top: 10px;
    font-size: 12px; color: #777;
  }

  /* Modal overlay — fade-in */
  .mps-overlay {
    display: none; position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 99999; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .mps-overlay.open { display: flex; }
  .mps-overlay.visible { opacity: 1; }

  /* Modal — slide-up */
  .mps-modal {
    background: #fff;
    padding: 28px;
    max-width: 480px; width: 92%;
    max-height: 85vh;
    max-height: 85dvh;
    overflow-y: auto; position: relative;
    transform: translateY(20px);
    opacity: 0;
    transition: transform 0.3s ease-out, opacity 0.3s ease-out;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.05);
  }
  .mps-overlay.visible .mps-modal {
    transform: translateY(0);
    opacity: 1;
  }

  /* Plan summary card */
  .mps-modal-summary {
    border: 1.5px solid {{ block.settings.accent_color }}30;
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 20px;
    background: {{ block.settings.accent_color }}08;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .mps-modal-summary-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mps-modal-summary-name {
    font-weight: 700;
    font-size: 15px;
    color: #111;
  }
  .mps-modal-summary-freq {
    font-size: 13px;
    color: #555;
  }
  .mps-modal-summary-right {
    text-align: right;
    flex-shrink: 0;
  }
  .mps-modal-summary-price {
    font-weight: 800;
    font-size: 18px;
    color: #111;
  }
  .mps-modal-summary-original {
    font-size: 12px;
    color: #999;
    text-decoration: line-through;
  }
  .mps-modal-summary-badge {
    display: inline-block;
    background: {{ block.settings.accent_color }};
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 4px;
  }

  .mps-modal-title { font-size: 20px; font-weight: 700; margin-bottom: 4px; color: #111; }
  .mps-modal-subtitle { font-size: 14px; color: #555; margin-bottom: 20px; }
  .mps-modal-close {
    position: absolute; top: 14px; right: 18px;
    background: none; border: none; font-size: 22px;
    cursor: pointer; color: #999; line-height: 1;
    width: 32px; height: 32px; display: flex;
    align-items: center; justify-content: center;
    border-radius: 50%;
    transition: background 0.15s;
  }
  .mps-modal-close:hover { background: #f0f0f0; color: #333; }

  /* Section headers */
  .mps-modal-section {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    margin-top: 6px;
    padding-bottom: 8px;
    border-bottom: 1px solid #eee;
  }
  .mps-modal-section svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: {{ block.settings.accent_color }};
  }
  .mps-modal-section span {
    font-size: 14px;
    font-weight: 600;
    color: #333;
  }

  .mps-field { margin-bottom: 14px; }
  .mps-field label {
    display: block; font-size: 13px; font-weight: 600;
    margin-bottom: 4px; color: #333;
  }
  .mps-field input {
    width: 100%; padding: 13px 16px; border: 1.5px solid #ddd;
    font-size: 15px; box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: #fff;
    color: #111;
  }
  .mps-field input:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
    box-shadow: 0 0 0 3px {{ block.settings.accent_color }}20;
  }
  .mps-field input:disabled {
    background: #f5f5f5;
    color: #999;
    cursor: not-allowed;
  }
  .mps-field-row { display: flex; gap: 10px; }
  .mps-field-row .mps-field { flex: 1; }
  .mps-error { color: #d72c0d; font-size: 13px; margin-bottom: 10px; min-height: 18px; }

  /* Modal submit with spinner */
  .mps-modal-submit {
    width: 100%; padding: 16px; margin-top: 4px;
    background: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none; border-radius: 10px;
    font-size: 17px; font-weight: 700;
    cursor: pointer; transition: opacity 0.2s;
    display: flex; align-items: center; justify-content: center;
    gap: 8px; min-height: 54px;
  }
  .mps-modal-submit:hover { opacity: 0.9; }
  .mps-modal-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .mps-spinner {
    animation: mps-spin 0.8s linear infinite;
    width: 22px;
    height: 22px;
  }
  @keyframes mps-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .mps-modal-trust {
    text-align: center; margin-top: 12px;
    font-size: 12px; color: #777;
  }

  @media (max-width: 480px) {
    .mps-field-row { flex-direction: column; gap: 0; }
    .mps-modal { padding: 20px; width: 95%; }
    .mps-modal-summary { flex-direction: column; text-align: center; }
    .mps-modal-summary-right { text-align: center; }
  }
</style>

<script>
(function() {
  var container = document.getElementById('mp-subscription-block');
  var shop = container.dataset.shop;
  var appUrl = (container.dataset.appUrl || '').replace(/\/+$/, '');
  var productTitle = container.dataset.productTitle;
  var variantId = container.dataset.variantId;

  /* Read modal config from data attributes */
  var showAddress = container.dataset.showAddress !== 'false';
  var showCity = container.dataset.showCity !== 'false';
  var showPhone = container.dataset.showPhone !== 'false';
  var showProvince = container.dataset.showProvince !== 'false';
  var showPostal = container.dataset.showPostal !== 'false';
  var modalBg = container.dataset.modalBg || '#ffffff';
  var modalOverlay = container.dataset.modalOverlay || '#000000';
  var modalTitle = container.dataset.modalTitle || 'Completa tus datos';
  var modalSubtitle = container.dataset.modalSubtitle || 'Para recibir tu suscripcion en tu domicilio';
  var modalRadius = (container.dataset.modalRadius || '16') + 'px';
  var inputRadius = (container.dataset.inputRadius || '8') + 'px';

  var hasShippingFields = showAddress || showCity || showProvince || showPostal;

  if (!appUrl) {
    container.innerHTML = '<p class="mps-load-error">Configura la App URL en los ajustes del bloque.</p>';
    return;
  }

  /* Escape HTML to prevent XSS from API data */
  function esc(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  var selectedPlanId = null;
  var selectedType = 'onetime';
  var plansData = null;

  fetch(appUrl + '/api/subscription?shop=' + encodeURIComponent(shop))
    .then(function(r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(data) {
      if (!data.plans || data.plans.length === 0) {
        container.innerHTML = '';
        return;
      }

      plansData = data.plans;
      var html = '';

      /* Subscription plans */
      html += '<div class="mps-title">{{ block.settings.section_title }}</div>';

      data.plans.forEach(function(plan) {
        var disc = plan.originalPrice > 0
          ? Math.round((1 - plan.amount / plan.originalPrice) * 100) : 0;
        var freqMap = { days: 'dias', weeks: 'semanas', months: 'mes', years: 'ano' };
        var freqLabel = 'cada ' + plan.frequency + ' ' + (freqMap[plan.frequencyType] || esc(plan.frequencyType));

        html += '<div class="mps-plan" data-plan-id="' + esc(plan.id) + '" data-type="subscription" role="radio" aria-checked="false" tabindex="0">';
        if (disc > 0) html += '<div class="mps-badge">' + disc + '% OFF</div>';
        html += '<div class="mps-plan-header">';
        html += '<div class="mps-plan-left">';
        html += '<div class="mps-radio" aria-hidden="true"><div class="mps-radio-dot"></div></div>';
        html += '<div><div class="mps-plan-name">' + esc(plan.name) + '</div>';
        html += '<div class="mps-plan-desc">' + esc(plan.description || (plan.quantity + ' un. ' + freqLabel)) + '</div></div>';
        html += '</div>';
        html += '<div class="mps-plan-right">';
        html += '<div class="mps-plan-price">$' + plan.amount.toLocaleString() + '<span style="font-size:14px;font-weight:400">/' + (plan.frequencyType === 'months' ? 'mes' : esc(freqLabel)) + '</span></div>';
        if (plan.originalPrice > 0) html += '<div class="mps-plan-original">$' + plan.originalPrice.toLocaleString() + '</div>';
        html += '</div></div></div>';
      });

      /* One-time purchase */
      html += '<div class="mps-onetime selected" data-type="onetime" role="radio" aria-checked="true" tabindex="0">';
      html += '<div class="mps-plan-header">';
      html += '<div class="mps-plan-left">';
      html += '<div class="mps-radio" aria-hidden="true"><div class="mps-radio-dot"></div></div>';
      html += '<div><div class="mps-plan-name">{{ block.settings.onetime_title }}</div>';
      html += '<div class="mps-plan-desc">Entrega unica</div></div>';
      html += '</div>';
      html += '<div class="mps-plan-right">';
      html += '<div class="mps-plan-price">' + esc(container.dataset.productPrice || '') + '</div>';
      html += '</div></div>';
      html += '<div class="mps-onetime-cons">';
      html += '<span>&#10005; {{ block.settings.onetime_con1 }}</span>';
      html += '<span>&#10005; {{ block.settings.onetime_con2 }}</span>';
      html += '</div></div>';

      /* CTA */
      html += '<button class="mps-cta" id="mps-cta">{{ block.settings.onetime_button }}</button>';
      html += '<div class="mps-trust">&#128274; {{ block.settings.trust_text }}</div>';

      /* Modal */
      html += '<div class="mps-overlay" id="mps-overlay" role="dialog" aria-modal="true" aria-label="Datos de envio" style="background:' + modalOverlay + '80">';
      html += '<div class="mps-modal" style="background:' + modalBg + ';border-radius:' + modalRadius + '">';
      html += '<button class="mps-modal-close" id="mps-modal-close" aria-label="Cerrar">&#10005;</button>';

      /* Plan summary card */
      html += '<div class="mps-modal-summary" id="mps-modal-summary"></div>';

      /* Title & subtitle */
      html += '<div class="mps-modal-title">' + esc(modalTitle) + '</div>';
      html += '<div class="mps-modal-subtitle">' + esc(modalSubtitle) + '</div>';

      html += '<div class="mps-error" id="mps-modal-error" role="alert"></div>';

      /* Section: Datos personales */
      html += '<div class="mps-modal-section">';
      html += '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';
      html += '<span>Datos personales</span>';
      html += '</div>';

      html += '<div class="mps-field"><label for="mps-email">Email *</label><input type="email" id="mps-email" placeholder="tu@email.com" autocomplete="email" required style="border-radius:' + inputRadius + '"></div>';
      html += '<div class="mps-field"><label for="mps-name">Nombre completo *</label><input type="text" id="mps-name" placeholder="Juan Perez" autocomplete="name" required style="border-radius:' + inputRadius + '"></div>';

      if (showPhone) {
        html += '<div class="mps-field"><label for="mps-phone">Telefono</label><input type="tel" id="mps-phone" placeholder="11-5555-1234" autocomplete="tel" style="border-radius:' + inputRadius + '"></div>';
      }

      /* Section: Datos de envio (only if at least 1 shipping field visible) */
      if (hasShippingFields) {
        html += '<div class="mps-modal-section" style="margin-top:10px">';
        html += '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>';
        html += '<span>Datos de envio</span>';
        html += '</div>';

        if (showAddress) {
          html += '<div class="mps-field"><label for="mps-address">Direccion</label><input type="text" id="mps-address" placeholder="Av. Corrientes 1234, Piso 3" autocomplete="street-address" style="border-radius:' + inputRadius + '"></div>';
        }

        /* City + Province row */
        var cityProvinceRow = showCity && showProvince;
        if (cityProvinceRow) {
          html += '<div class="mps-field-row">';
        }
        if (showCity) {
          html += '<div class="mps-field"><label for="mps-city">Ciudad</label><input type="text" id="mps-city" placeholder="CABA" autocomplete="address-level2" style="border-radius:' + inputRadius + '"></div>';
        }
        if (showProvince) {
          html += '<div class="mps-field"><label for="mps-province">Provincia</label><input type="text" id="mps-province" placeholder="Buenos Aires" autocomplete="address-level1" style="border-radius:' + inputRadius + '"></div>';
        }
        if (cityProvinceRow) {
          html += '</div>';
        }

        if (showPostal) {
          html += '<div class="mps-field" style="max-width:180px"><label for="mps-postal">Codigo postal</label><input type="text" id="mps-postal" placeholder="1043" autocomplete="postal-code" style="border-radius:' + inputRadius + '"></div>';
        }
      }

      html += '<button class="mps-modal-submit" id="mps-modal-submit">{{ block.settings.subscribe_button }}</button>';
      html += '<div class="mps-modal-trust">&#128274; Pago seguro via MercadoPago. Cancela cuando quieras.</div>';
      html += '</div></div>';

      container.innerHTML = html;

      /* Selection logic */
      var allCards = container.querySelectorAll('.mps-plan, .mps-onetime');
      var cta = document.getElementById('mps-cta');

      function selectCard(el) {
        allCards.forEach(function(c) {
          c.classList.remove('selected');
          c.setAttribute('aria-checked', 'false');
        });
        el.classList.add('selected');
        el.setAttribute('aria-checked', 'true');

        if (el.dataset.type === 'subscription') {
          selectedType = 'subscription';
          selectedPlanId = el.dataset.planId;
          cta.textContent = '{{ block.settings.subscribe_button }}';
        } else {
          selectedType = 'onetime';
          selectedPlanId = null;
          cta.textContent = '{{ block.settings.onetime_button }}';
        }
      }

      allCards.forEach(function(el) {
        el.addEventListener('click', function() { selectCard(el); });
        el.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectCard(el); }
        });
      });

      /* Modal open/close with animation */
      var overlay = document.getElementById('mps-overlay');

      function openModal() {
        overlay.classList.add('open');
        /* Trigger reflow before adding visible class for animation */
        void overlay.offsetHeight;
        overlay.classList.add('visible');
        var emailField = document.getElementById('mps-email');
        if (emailField) emailField.focus();
      }

      function closeModal() {
        overlay.classList.remove('visible');
        setTimeout(function() {
          overlay.classList.remove('open');
        }, 300);
        document.getElementById('mps-modal-error').textContent = '';
      }

      /* CTA click */
      cta.addEventListener('click', function() {
        if (selectedType === 'onetime') {
          var formEl = document.querySelector('form[action="/cart/add"]');
          if (formEl) {
            formEl.submit();
          } else {
            window.location.href = '/cart/add?id=' + encodeURIComponent(variantId) + '&quantity=1';
          }
        } else {
          if (!plansData) return;
          var plan = plansData.find(function(p) { return p.id === selectedPlanId; });
          if (!plan) return;

          /* Populate plan summary card */
          var summaryEl = document.getElementById('mps-modal-summary');
          var freqMap2 = { months: 'mes', days: 'dias', weeks: 'semanas', years: 'ano' };
          var freqText = plan.frequency + ' ' + (freqMap2[plan.frequencyType] || plan.frequencyType);
          var disc = plan.originalPrice > 0 ? Math.round((1 - plan.amount / plan.originalPrice) * 100) : 0;

          var summaryHtml = '<div class="mps-modal-summary-left">';
          if (disc > 0) summaryHtml += '<span class="mps-modal-summary-badge">' + disc + '% OFF</span>';
          summaryHtml += '<span class="mps-modal-summary-name">' + esc(plan.name) + '</span>';
          summaryHtml += '<span class="mps-modal-summary-freq">' + esc(plan.quantity + ' un. / ' + freqText) + '</span>';
          summaryHtml += '</div>';
          summaryHtml += '<div class="mps-modal-summary-right">';
          summaryHtml += '<div class="mps-modal-summary-price">$' + plan.amount.toLocaleString() + '<span style="font-size:13px;font-weight:400">/' + (freqMap2[plan.frequencyType] || plan.frequencyType) + '</span></div>';
          if (plan.originalPrice > 0) summaryHtml += '<div class="mps-modal-summary-original">$' + plan.originalPrice.toLocaleString() + '</div>';
          summaryHtml += '</div>';
          summaryEl.innerHTML = summaryHtml;

          openModal();
        }
      });

      /* Modal close handlers */
      document.getElementById('mps-modal-close').addEventListener('click', closeModal);
      overlay.addEventListener('click', function(e) {
        if (e.target === this) closeModal();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && overlay.classList.contains('open')) {
          closeModal();
        }
      });

      /* Modal submit */
      document.getElementById('mps-modal-submit').addEventListener('click', function() {
        var errorEl = document.getElementById('mps-modal-error');
        var btn = this;
        errorEl.textContent = '';

        var email = document.getElementById('mps-email').value.trim();
        var name = document.getElementById('mps-name').value.trim();
        var addressEl = document.getElementById('mps-address');
        var cityEl = document.getElementById('mps-city');
        var provinceEl = document.getElementById('mps-province');
        var postalEl = document.getElementById('mps-postal');
        var phoneEl = document.getElementById('mps-phone');

        var address = addressEl ? addressEl.value.trim() : '';
        var city = cityEl ? cityEl.value.trim() : '';
        var province = provinceEl ? provinceEl.value.trim() : '';
        var postal = postalEl ? postalEl.value.trim() : '';
        var phone = phoneEl ? phoneEl.value.trim() : '';

        /* Validation — only email and name are always required */
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errorEl.textContent = 'Ingresa un email valido.'; document.getElementById('mps-email').focus(); return; }
        if (!name || name.length < 2) { errorEl.textContent = 'Ingresa tu nombre completo.'; document.getElementById('mps-name').focus(); return; }

        /* Loading state */
        btn.disabled = true;
        btn.innerHTML = '<svg class="mps-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" opacity=".3"/><path d="M12 2v4"/></svg>';
        var allInputs = container.querySelectorAll('.mps-modal input');
        allInputs.forEach(function(i) { i.disabled = true; });

        fetch(appUrl + '/api/subscription', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            planId: selectedPlanId,
            shop: shop,
            email: email,
            name: name,
            phone: phone,
            address: address,
            city: city,
            province: province,
            postalCode: postal,
            productTitle: productTitle,
            appUrl: appUrl
          })
        })
        .then(function(r) {
          if (!r.ok) return r.json().then(function(err) { throw new Error(err.error || 'Error del servidor'); });
          return r.json();
        })
        .then(function(result) {
          if (result.initPoint) {
            window.location.href = result.initPoint;
          } else {
            errorEl.textContent = result.error || 'Error al crear la suscripcion.';
            btn.disabled = false;
            btn.innerHTML = '{{ block.settings.subscribe_button }}';
            allInputs.forEach(function(i) { i.disabled = false; });
          }
        })
        .catch(function(err) {
          errorEl.textContent = err.message || 'Error de conexion. Intenta de nuevo.';
          btn.disabled = false;
          btn.innerHTML = '{{ block.settings.subscribe_button }}';
          allInputs.forEach(function(i) { i.disabled = false; });
        });
      });
    })
    .catch(function() {
      container.innerHTML = '<p class="mps-load-error">No se pudieron cargar las opciones de suscripcion.</p>';
    });
})();
</script>

